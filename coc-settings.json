{
    "coc.preferences.formatOnSave": [
        "css",
        "go",
        "typescript",
        "ruby",
        "markdown",
        "javascript",
        "graphql",
        "html",
        "yaml",
        "json",
        "python",
        "haskell",
        "c",
        "rust"
    ],
    "coc.preferences.formatOptions": {
        "c": {
            "command": "clang-format",
            "args": [
                "-style=gnu"
            ],
            "rootPatterns": [
                ".clang-format",
            ]
        },
        "cpp": {
            "command": "clang-format",
            "args": [
                "-style=gnu"
            ],
            "rootPatterns": [
                ".clang-format",
            ]
        }
    },
    // python config
    // explorer
    "explorer.width": 30,
    "explorer.icon.enableNerdfont": true,
    "explorer.previewAction.onHover": false,
    "explorer.keyMappings.global": {
        "<cr>": [
            "expandable?",
            "expand",
            "open"
        ],
        "v": "open:vsplit"
    }
}
