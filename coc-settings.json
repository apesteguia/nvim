{
    "coc.preferences.formatOnSave": [
        "css",
        "go",
        "typescript",
        "ruby",
        "markdown",
        "javascript",
        "graphql",
        "html",
        "yaml",
        "json",
        "haskell",
        "c",
        "rust",
        "go"
    ],
    "python.linting.flake8Enabled": true,
    "languageserver": {
        "go": {
            "command": "gopls",
            "rootPatterns": [
                "go.work",
                "go.mod",
                ".vim/",
                ".git/",
                ".hg/"
            ],
            "filetypes": [
                "go"
            ],
            "initializationOptions": {
                "usePlaceholders": true
            }
        },
        "solargraph": {
            "command": "bundle",
            "args": [
                "exec",
                "solargraph",
                "stdio"
            ],
            "filetypes": [
                "ruby"
            ],
            "initializationOptions": {},
            "settings": {},
            "rootPatterns": [
                "Gemfile",
                ".git"
            ],
            "trace.server": "verbose",
            "workspaceFolder": null
        }
    },
    "coc.preferences.formatOptions": {
        "c": {
            "command": "clang-format",
            "args": [
                "-style=gnu"
            ],
            "rootPatterns": [
                ".clang-format",
            ]
        },
        "cpp": {
            "command": "clang-format",
            "args": [
                "-style=gnu"
            ],
            "rootPatterns": [
                ".clang-format",
            ]
        }
    },
    // python config
    // explorer
    "explorer.width": 30,
    "explorer.icon.enableNerdfont": true,
    "explorer.previewAction.onHover": false,
    "explorer.keyMappings.global": {
        "<cr>": [
            "expandable?",
            "expand",
            "open"
        ],
        "v": "open:vsplit"
    },
    "svelte.enable-ts-plugin": true
}
